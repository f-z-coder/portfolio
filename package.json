    "framer-motion": "12.38.0",
    "lucide-react": "0.440.0",
    "next": "16.2.3",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "4.2.0",
    "sharp": "0.34.5",
    "tailwind-merge": "3.5.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
